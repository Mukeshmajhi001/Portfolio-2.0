# Uploads folder — CRITICAL security
Options -Indexes -ExecCGI

# Block ALL PHP execution in uploads
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|phar|cgi|pl|py|asp|aspx|sh|bash)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Only allow images
<FilesMatch "\.(jpg|jpeg|png|webp|gif)$">
  Order Allow,Deny
  Allow from all
</FilesMatch>

# Remove PHP handler just in case
RemoveHandler .php .phtml
RemoveType   .php .phtml
